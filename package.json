{
  "name": "mechvibes-ada",
  "productName": "Mechvibes Ada",
  "version": "2.5.0",
  "description": "Play mechanical keyboard sounds as you type, with adaptive volume and Latin American Spanish support.",
  "repository": "https://github.com/EduCVergara/mechvibesAda",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build:all": "electron-builder -wml",
    "build:win": "electron-builder -w",
    "build:mac": "electron-builder -m",
    "build:linux": "electron-builder -l",
    "build:clean": "node tools/clean-dist.js"
  },
  "keywords": [],
  "homepage": "https://mechvibes.com",
  "author": {
    "name": "Hai Nguyen",
    "email": "hainguyen.ts13@gmail.com"
  },
  "contributors": [
    {
      "name": "EduCVergara",
      "url": "https://github.com/EduCVergara"
    }
  ],
  "license": "MIT",
  "build": {
    "files": [
      "src/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/easy-volume/dist/platforms/windows/volume.exe",
      "node_modules/uiohook-napi/**/*"
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "include": "./build/installer.nsh"
    },
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "src/assets/icon.png"
    },
    "mac": {
      "category": "public.app-category.entertainment",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "src/assets/icon.png"
    },
    "linux": {
      "category": "Utility",
      "target": [
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "snap",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "src/assets/icon.png"
    }
  },
  "dependencies": {
    "adm-zip": "^0.5.17",
    "easy-volume": "^1.2.0",
    "electron-log": "^5.4.4",
    "fs-extra": "^11.3.5",
    "howler": "^2.2.4",
    "mime-types": "^3.0.2",
    "uiohook-napi": "^1.5.5"
  },
  "devDependencies": {
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3"
  }
}
